scene.txt

# Go workspace
# go.work is committed (see shared/ module + AI-agent resolution rationale
# in docs/ui-style-guide.md). go.work.sum is ignored — it tracks indirect
# dependency hashes that drift with local toolchain versions.
go.work.sum

# Vendor (dependencies fetched by go mod)
vendor/
# …except the web-asset vendor dir: Chart.js + plugins are committed and
# //go:embed-ed into the binary for air-gapped plant deploys (no CDN). See
# plan-mission-telemetry-v1 §6.
!shingo-core/www/static/vendor/
!shingo-core/www/static/vendor/**

# API reference docs (scraped, not source)
seer-docs/

# Python artifacts (for any utility scripts)
__pycache__/
*.pyc

# Debug logs
shingo-debug*.log
**/shingo-debug*.log

# Personal notes
*.notes.md

# Planning docs and reference PDFs
payload-plan.md
API_Docs.pdf
docs/order-patterns

# AI agent config
CLAUDE.md
AGENTS.md
